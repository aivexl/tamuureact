{
  "name": "tamuu",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@tamuu/web",
    "dev:api": "turbo run dev --filter=@tamuu/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@tamuu/web",
    "build:main": "turbo run build --filter=@tamuu/main",
    "build:api": "turbo run build --filter=@tamuu/api",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "vitest run",
    "clean": "turbo run clean && rm -rf node_modules",
    "deploy": "turbo run deploy",
    "deploy:api": "turbo run deploy:api --filter=@tamuu/api",
    "deploy:main": "cd apps/main && npm run build:worker && npx wrangler deploy && npx wrangler pages deploy .open-next/assets --project-name tamuu",
    "deploy:web:landing": "turbo run build:worker --filter=@tamuu/main && npx wrangler pages deploy apps/main/.open-next/assets --project-name tamuu",
    "deploy:web:app": "turbo run build --filter=@tamuu/web && npx wrangler pages deploy apps/web/dist --project-name tamuu-app"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@types/jest": "^30.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "react-easy-crop": "^5.5.6"
  }
}
